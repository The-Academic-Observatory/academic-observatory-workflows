SELECT DISTINCT TRIM(location.source.host_organization_name) as repository_institution
FROM `{{ openalex_works_fqid }}` as works, UNNEST(works.locations) as location
WHERE location.source.type = "repository"
  AND location.source.host_organization_name IS NOT NULL
  AND TRIM(location.source.host_organization_name) != ""
  AND location.is_oa = true
ORDER BY repository_institution ASC


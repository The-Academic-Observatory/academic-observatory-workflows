{#
  REFACTOR NOTE:
  The original query built large intermediate arrays per (aggregator, year) group inline inside
  tmp_agg_table, which caused BigQuery to OOM when aggregators (e.g. large publishers) had
  hundreds of thousands of DOIs.

  The fix pre-aggregates each relation type (institutions, countries, funders, etc.) into its own
  CTE keyed on (aggregator_id, relation_id, time_period). Each row in these CTEs contains only
  the summarised per-relation-per-DOI data needed by process_relations — crucially, the disciplines
  array is already reduced to one row per DisplayName at this point, not one row per concept per DOI.

  In tmp_agg_table, instead of ARRAY_CONCAT_AGG(ARRAY(SELECT ... FROM UNNEST(affiliations.X))),
  we do a simple ARRAY_AGG over the pre-aggregated CTE rows, which is dramatically smaller.

  The output schema is identical to the original.
#}


{% if relation_type == 'groups' %}{% set relation_col = 'groups' %}
{% elif relation_type == 'funders' %}{% set relation_col = 'funders_rel' %}
{% elif relation_type == 'members' %}{% set relation_col = 'members' %}
{% else %}{% set relation_col = relation_type %}
{% endif %}

-- Relation query: direct aggregation, no intermediate arrays.
--
-- The original process_relations function worked by collecting all per-DOI
-- data into a large array and then aggregating inside the function. That
-- approach OOMs for large publishers now that the data has grown.
--
-- This query produces an identical output schema by replacing the array
-- accumulation with direct COUNTIF/SUM aggregations and a nested
-- GROUP BY for disciplines. No large intermediate arrays are ever built.

WITH

-- Step 1: one row per (aggregator, relation, doi).
-- Concepts stay as an array — no cross join with relations.
tmp_per_doi AS (
  SELECT
    flat.aggregator_id,
    flat.time_period,
    relation.identifier                         AS relation_identifier,
    relation.name                               AS relation_name,
    relation.country                            AS relation_country,
    relation.country_code                       AS relation_country_code,
    relation.region                             AS relation_region,
    relation.subregion                          AS relation_subregion,
    relation.coordinates                        AS relation_coordinates,
    -- OA booleans directly — no struct array needed
    flat.oa.color.oa                            AS is_oa,
    flat.oa.color.green                         AS is_green,
    flat.oa.color.gold                          AS is_gold,
    flat.oa.color.gold_just_doaj                AS is_gold_just_doaj,
    flat.oa.color.hybrid                        AS is_hybrid,
    flat.oa.color.bronze                        AS is_bronze,
    flat.oa.color.green_only                    AS is_green_only,
    flat.oa.color.green_only_ignoring_bronze    AS is_green_only_ignoring_bronze,
    flat.oa.color.black                         AS is_black,
    flat.oa.license.has_license                 AS has_license,
    flat.oa.license.is_cclicensed               AS is_cclicensed,
    flat.oa.coki.open                           AS coki_open,
    flat.citations_openalex,
    flat.citations_crossref,
    flat.citations_open_citations,
    flat.concepts                               AS concepts
  FROM `{{ flat_table_id }}` AS flat,
    UNNEST(flat.{{ relation_col }}) AS relation
  WHERE relation.identifier IS NOT NULL
),

-- Step 2: aggregate to (aggregator, relation, year).
-- All counts computed directly — no ARRAY_AGG of OA structs.
tmp_relations AS (
  SELECT
    aggregator_id,
    time_period,
    relation_identifier,
    MAX(relation_name)                          AS relation_name,
    MAX(relation_country)                       AS relation_country,
    MAX(relation_country_code)                  AS relation_country_code,
    MAX(relation_region)                        AS relation_region,
    MAX(relation_subregion)                     AS relation_subregion,
    MAX(relation_coordinates)                   AS relation_coordinates,
    COUNT(*)                                    AS total_outputs,
    -- OA counts: direct COUNTIF, no array accumulation
    COUNTIF(is_oa)                              AS num_oa_outputs,
    COUNTIF(is_green)                           AS num_green_outputs,
    COUNTIF(is_gold)                            AS num_gold_outputs,
    COUNTIF(is_gold_just_doaj)                  AS num_gold_just_doaj_outputs,
    COUNTIF(is_hybrid)                          AS num_hybrid_outputs,
    COUNTIF(is_bronze)                          AS num_bronze_outputs,
    COUNTIF(is_green_only)                      AS num_green_only_outputs,
    COUNTIF(is_green_only_ignoring_bronze)      AS num_green_only_ignoring_bronze_outputs,
    COUNTIF(is_black)                           AS num_black,
    COUNTIF(has_license)                        AS num_has_license,
    COUNTIF(is_cclicensed)                      AS num_is_cclicensed,
    COUNTIF(coki_open)                          AS num_coki_open,
    -- Citations: direct SUM
    SUM(citations_openalex)                     AS citations_openalex,
    SUM(citations_crossref)                     AS citations_crossref,
    SUM(citations_open_citations)               AS citations_open_citations,
    -- Disciplines: ARRAY_CONCAT_AGG merges per-DOI concept arrays,
    -- group_disciplines then groups by DisplayName.
    -- This is the same approach as the original query and is safe because
    -- concepts is a small array (max 18 per your data) so the concat
    -- stays manageable.
    group_disciplines(
      ARRAY_CONCAT_AGG(concepts)
    )                                           AS disciplines
  FROM tmp_per_doi
  GROUP BY aggregator_id, time_period, relation_identifier
)

-- Step 3: one row per (aggregator, year) with the relation array.
-- Reconstruct the same output schema as process_relations, using the
-- pre-computed counts from tmp_relations instead of re-aggregating arrays.
SELECT
  r.aggregator_id                               AS id,
  r.time_period,
  ARRAY_AGG(STRUCT(
    r.relation_identifier                       AS id,
    r.total_outputs                             AS total_outputs,
    ROUND(SAFE_DIVIDE(r.total_outputs, base.total_outputs), 3)
                                                AS percentage_of_all_outputs,
    ROUND(SAFE_DIVIDE(r.num_coki_open, base.total_oa_outputs), 3)
                                                AS percentage_of_all_oa,
    r.relation_name                             AS name,
    r.relation_country                          AS country,
    r.relation_country_code                     AS country_code,
    r.relation_region                           AS region,
    r.relation_subregion                        AS subregion,
    r.relation_coordinates                      AS coordinates,
    -- count_access_types fields inlined directly
    r.num_oa_outputs,
    r.num_green_outputs,
    r.num_gold_outputs,
    r.num_gold_just_doaj_outputs,
    r.num_hybrid_outputs,
    r.num_bronze_outputs,
    r.num_green_only_outputs,
    r.num_green_only_ignoring_bronze_outputs,
    r.num_black,
    r.num_has_license,
    r.num_is_cclicensed,
    STRUCT(
      r.citations_openalex                      AS openalex,
      r.citations_crossref                      AS crosssref,
      r.citations_open_citations                AS open_citations
    )                                           AS citations,
    r.disciplines                               AS disciplines
  ) ORDER BY r.total_outputs DESC LIMIT 1000)   AS {{ relation_type }}
FROM tmp_relations AS r
INNER JOIN `{{ base_table_id }}` AS base
  ON r.aggregator_id = base.id
  AND r.time_period = base.time_period
GROUP BY r.aggregator_id, r.time_period
